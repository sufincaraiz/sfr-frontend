generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Geographic hierarchy ────────────────────────────────────────────────────

model Municipality {
  id           String     @id @default(uuid())
  slug         String     @unique
  name         String
  province     String     @default("Cundinamarca")
  demand_score Int        @default(0)
  veredas      Vereda[]
  properties   Property[]

  @@map("municipalities")
}

model Vereda {
  id              String       @id @default(uuid())
  slug            String
  name            String
  municipality_id String
  lat             Float?
  lng             Float?
  municipality    Municipality @relation(fields: [municipality_id], references: [id])
  properties      Property[]

  @@unique([slug, municipality_id])
  @@map("veredas")
}

// ─── Core ────────────────────────────────────────────────────────────────────

model Property {
  id               String          @id @default(uuid())
  slug             String          @unique
  type             String          // finca | lote | casa | apartamento | condominio | local
  transaction_type String          @default("venta")
  municipality_id  String
  vereda_id        String?
  address_visible  String?
  price_cop        BigInt
  area_lot_m2      Float?
  area_built_m2    Float?
  bedrooms         Int             @default(0)
  bathrooms        Int             @default(0)
  parking          Int             @default(0)
  year_built       Int?
  status           String          @default("available") // available | reserved | sold
  geo_lat          Float?
  geo_lng          Float?
  published_at     DateTime        @default(now())
  updated_at       DateTime        @updatedAt
  // SEO / content
  title            String?
  short_description String?
  description      String?
  meta_title       String?
  meta_description String?
  // Media embeds
  video_url        String?
  virtual_tour_url String?
  // Relations
  municipality     Municipality    @relation(fields: [municipality_id], references: [id])
  vereda           Vereda?         @relation(fields: [vereda_id], references: [id])
  media            PropertyMedia[]
  features         PropertyFeature[]
  leads            Lead[]

  @@index([municipality_id, status, price_cop])
  @@index([vereda_id, status])
  @@index([type, status])
  @@map("properties")
}

model PropertyFeature {
  id            String   @id @default(uuid())
  property_id   String
  feature_key   String
  feature_value String
  property      Property @relation(fields: [property_id], references: [id], onDelete: Cascade)

  @@map("property_features")
}

model PropertyMedia {
  id                String   @id @default(uuid())
  property_id       String
  type              String   // image | video | tour360
  tour360_type      String?  // self_hosted | embed
  tour360_embed_url String?
  url               String
  order             Int      @default(0)
  alt_text          String   @default("")
  is_primary        Boolean  @default(false)
  property          Property @relation(fields: [property_id], references: [id], onDelete: Cascade)

  @@map("property_media")
}

// ─── Agents ─────────────────────────────────────────────────────────────────

model Agent {
  id      String  @id @default(uuid())
  name    String
  slug    String  @unique
  photo   String?
  license String?
  whatsapp String
  email   String  @unique
  leads   Lead[]

  @@map("agents")
}

// ─── Leads ──────────────────────────────────────────────────────────────────

enum LeadQualification {
  SIN_CALIFICAR
  CALIENTE
  TIBIO
  FRIO
  VACIO
  DESCARTADO
}

enum LeadPipeline {
  NUEVO
  CONTACTADO
  VISITA_AGENDADA
  EN_NEGOCIACION
  CERRADO_GANADO
  CERRADO_PERDIDO
}

model Lead {
  id                String            @id @default(uuid())
  property_id       String?
  name              String
  phone             String
  email             String
  channel           String            @default("web")
  message           String?
  utm_source        String?
  utm_medium        String?
  utm_campaign      String?
  created_at        DateTime          @default(now())
  status            String            @default("new")
  assigned_agent_id String?
  // Mac agent fields
  qualification     LeadQualification @default(SIN_CALIFICAR)
  budgetMin         Int?
  budgetMax         Int?
  interestType      String?
  interestZone      String?
  timeframe         String?
  financing         String?
  agentNotes        String?           @db.Text
  source            String?
  portalAdId        String?
  pipeline          LeadPipeline      @default(NUEVO)
  nextAction        String?
  nextActionDate    DateTime?
  lastContactAt     DateTime?
  property          Property?         @relation(fields: [property_id], references: [id], onDelete: SetNull)
  agent             Agent?            @relation(fields: [assigned_agent_id], references: [id])
  conversations     Conversation[]

  @@map("leads")
}

// ─── Agent conversations ─────────────────────────────────────────────────────

enum Channel {
  WEB
  WHATSAPP
  TELEGRAM
  APP
}

enum ConvStatus {
  ACTIVE
  ESCALATED
  CLOSED
}

enum MsgRole {
  USER
  ASSISTANT
}

model Conversation {
  id          String     @id @default(cuid())
  channel     Channel    @default(WEB)
  externalId  String
  leadId      String?
  lead        Lead?      @relation(fields: [leadId], references: [id])
  status      ConvStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  messages    Message[]

  @@unique([channel, externalId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  role           MsgRole
  content        String       @db.Text
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ─── Admin ──────────────────────────────────────────────────────────────────

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  nombre    String
  role      String   @default("admin")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("admins")
}

// ─── Content ────────────────────────────────────────────────────────────────

model Article {
  id               String   @id @default(uuid())
  slug             String   @unique
  title            String
  excerpt          String?
  content          String   @db.Text
  cover_image_url  String?
  published_at     DateTime?
  updated_at       DateTime @updatedAt
  meta_title       String?
  meta_description String?
  // Aportes de la comunidad (blog colaborativo)
  author_name      String?
  author_photo_url String?
  author_email     String?
  created_at       DateTime @default(now())

  @@map("articles")
}

model Business {
  id              String   @id @default(uuid())
  nombre          String
  imagen_url      String?  // legacy: portada única (respaldo). Ahora se usa `imagenes`.
  imagenes        String[] @default([]) // hasta 5 fotos; imagenes[0] = portada
  descripcion     String?  // descripción corta
  categoria       String   // Restaurante | Ferretería | Droguería | Vivero | Otros
  municipio       String   @default("La Vega")
  whatsapp        String?
  domicilios      Boolean  @default(false)
  google_maps_url String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([categoria])
  @@index([municipio])
  @@map("businesses")
}

model PageContent {
  id         String   @id @default(uuid())
  key        String   @unique
  data       Json
  updated_at DateTime @updatedAt

  @@map("page_content")
}

model Redirect {
  id          String @id @default(uuid())
  source      String @unique
  destination String
  permanent   Boolean @default(true)

  @@map("redirects")
}

model SearchLog {
  id          String   @id @default(uuid())
  query       String?
  tipo        String?
  municipio   String?
  precio_max  BigInt?
  results     Int      @default(0)
  created_at  DateTime @default(now())

  @@map("search_logs")
}
