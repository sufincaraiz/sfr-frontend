# ──────────────────────────────────────────────────────────────
# Su Finca Raíz — Frontend — Variables de entorno
# Copia este archivo como .env.local y completa los valores reales
# NUNCA commitees .env.local al repositorio
# ──────────────────────────────────────────────────────────────

# URL del backend API (en producción usar la URL de tu servidor/Railway/Render)
NEXT_PUBLIC_API_URL=http://localhost:4000

# URL pública del sitio (sin trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.sufincaraiz.com

# Cloudinary — cloud name público (safe para frontend)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Cloudinary — upload preset sin firma (creado en Cloudinary Dashboard > Settings > Upload)
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Google Search Console — código de verificación (optional)
NEXT_PUBLIC_GSC_VERIFICATION=
